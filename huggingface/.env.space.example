# Hermes Agent / Hugging Face Space 环境变量模板
#
# 这个文件只会在首次启动时复制到 /data/.env。
# 真正部署时，优先把密钥配置在 Hugging Face Space 的 Secrets / Variables 中。
# 这里尽量只保留说明，不直接写会覆盖运行时环境变量的实际值。
#
# =========================
# API Server 基础配置
# =========================
# API_SERVER_KEY=                       # API 服务访问密钥；绑定 0.0.0.0 时必须配置强随机值
# API_SERVER_MODEL_NAME=Hermes-Agent    # /v1/models 接口中展示的模型名称
# API_SERVER_CORS_ORIGINS=              # 允许跨域访问的来源，多个值可用逗号分隔
#
# =========================
# Hermes 运行目录
# =========================
# HERMES_HOME=/data                     # Hermes 持久化目录；HF Storage 挂载路径建议固定为 /data
#
# =========================
# 自定义 OpenAI-compatible 模型接口（主模型）
# =========================
# ACTIVE_CUSTOM_MODEL=primary                                        # 当前激活哪套模型：primary 或 secondary
# CUSTOM_OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1  # 主模型接口地址；要求兼容 OpenAI Chat Completions
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1         # 主模型可选别名；若你更习惯 OpenAI 风格变量名，也可用它代替 CUSTOM_OPENAI_BASE_URL
# HERMES_MODEL=Qwen/qwen-max-latest                                  # 主模型名；写入 model.default
# OPENAI_API_KEY=                                                    # 主模型接口认证密钥；Hermes 默认读取这个变量
# ANTHROPIC_API_KEY=                                                 # 如果你的服务商要求你使用这个变量名，也可配置；entrypoint 会兜底映射到 OPENAI_API_KEY
# ANTHROPIC_APILKEY=                                                 # 兼容你当前上游使用的这个变量名；entrypoint 也会兜底映射到 OPENAI_API_KEY
# HERMES_INFERENCE_PROVIDER=custom                                   # 可选；通常有 CUSTOM_OPENAI_BASE_URL / OPENAI_BASE_URL 时会自动切到 custom
#
# =========================
# 自定义 OpenAI-compatible 模型接口（第二套备选模型）
# =========================
# SECONDARY_CUSTOM_OPENAI_BASE_URL=https://your-second-endpoint/v1   # 第二套模型接口地址
# SECONDARY_OPENAI_BASE_URL=https://your-second-endpoint/v1          # 第二套模型可选别名
# SECONDARY_HERMES_MODEL=deepseek-expert-reasoner-search            # 第二套模型名
# SECONDARY_OPENAI_API_KEY=                                          # 第二套模型接口认证密钥
# SECONDARY_ANTHROPIC_API_KEY=                                       # 第二套模型接口若使用这个变量名，也可配置
# SECONDARY_ANTHROPIC_APILKEY=                                       # 第二套模型接口的兼容别名
#
# 说明：
# - 当前 HF 方案默认面向“自定义 OpenAI-compatible 接口”
# - 当 ACTIVE_CUSTOM_MODEL=primary 时，使用主模型变量
# - 当 ACTIVE_CUSTOM_MODEL=secondary 时，使用 SECONDARY_* 变量
# - 启动脚本会把激活模型同步写入 model.provider/model.base_url/model.default
# - 对于 custom endpoint，Hermes 主要使用 OPENAI_API_KEY 做认证
# - 如果你只有 ANTHROPIC_API_KEY 或 ANTHROPIC_APILKEY，启动脚本会在 OPENAI_API_KEY 为空时自动兜底复用它
# - 第二套模型同理，优先使用 SECONDARY_OPENAI_API_KEY，否则回落到 SECONDARY_ANTHROPIC_API_KEY / SECONDARY_ANTHROPIC_APILKEY
# - 你的上游接口需要保持兼容 OpenAI Chat Completions
#
# 如果你后续真的改用其他 provider，再按需自行补充对应变量；当前模板默认不再预置 HF/OpenRouter/Gemini 的模型配置
#
# =========================
# Weixin（个人微信）自动引导配置
# =========================
# WEIXIN_ENABLED=true                   # 启用 Weixin 渠道；设置后容器启动时会检查微信登录状态
# WEIXIN_AUTO_QR_LOGIN=true             # 当缺少微信凭据时，自动进入二维码扫码登录流程
# WEIXIN_QR_TIMEOUT_SECONDS=480         # 二维码登录等待超时时间，单位秒
# WEIXIN_AUTO_SET_HOME_CHANNEL=true     # 扫码成功后自动把返回的微信 user_id 设为 home channel
#
# =========================
# Weixin（个人微信）凭据
# =========================
# WEIXIN_ACCOUNT_ID=                    # 微信 iLink Bot account_id；扫码成功后会自动写入
# WEIXIN_TOKEN=                         # 微信 iLink Bot token；扫码成功后会自动写入
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com         # 微信 iLink Bot API 地址
# WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c  # 微信媒体 CDN 地址
#
# =========================
# Weixin（个人微信）权限控制
# =========================
# WEIXIN_DM_POLICY=open                 # 私聊策略：open / allowlist / pairing / disabled
# WEIXIN_GROUP_POLICY=disabled          # 群聊策略：open / allowlist / disabled
# WEIXIN_ALLOWED_USERS=user_id_1,user_id_2          # 私聊白名单用户 ID，逗号分隔
# WEIXIN_GROUP_ALLOWED_USERS=group_id_1,group_id_2  # 群聊白名单群 ID，逗号分隔
#
# =========================
# Weixin（个人微信）通知回投
# =========================
# WEIXIN_HOME_CHANNEL=chat_id           # 微信默认主频道/chat_id；用于 cron 或通知投递
# WEIXIN_HOME_CHANNEL_NAME=Home         # 默认主频道显示名称
#
# 推荐流程：
# 1. 在 HF 里至少设置 API_SERVER_KEY、HERMES_INFERENCE_PROVIDER、HERMES_MODEL 和对应 provider 密钥
# 2. 如果要启用微信，设置 WEIXIN_ENABLED=true
# 3. 首次启动时，如果 WEIXIN_ACCOUNT_ID / WEIXIN_TOKEN 不存在，entrypoint 会自动触发二维码登录
# 4. 二维码链接/状态会打印到 Space 日志中，扫码成功后会把凭据写入 /data/.env
# 5. 后续重启时会直接复用持久化的微信凭据
